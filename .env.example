# Geocoding API Key (Google Maps Geocoding API).
# Used in /api/geocode to reverse-geocode coordinates to city names.
# If unset, falls back to the free Nominatim (OpenStreetMap) API.
GEOCODING_API_KEY=""

# Gemini API Key (required for /api/reflection daily AI reflections).
# If unset, the reflection endpoint returns a 500 and the daily panel
# shows only the verse/hadith without AI commentary.
GEMINI_API_KEY=""

# Groq API Key (optional fallback for /api/reflection if Gemini fails).
GROQ_API_KEY=""

# WTH-022: removed dead NEXT_PUBLIC_WEATHER_API_KEY. The weather route
# uses Open-Meteo (no key required). A NEXT_PUBLIC_ var would be
# bundled into the client — a footgun if someone filled it in.
